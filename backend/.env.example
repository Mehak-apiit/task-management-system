# Server Configuration
PORT=8000
NODE_ENV=development

# Database Configuration
# Options: postgres, mysql, mongodb
DB_TYPE=mongodb

# PostgreSQL Connection String (when DB_TYPE=postgres)
POSTGRES_URL="postgresql://username:password@localhost:5432/task_management?schema=public"

# MySQL Connection String (when DB_TYPE=mysql)
MYSQL_URL="mysql://username:password@localhost:3307/task_management"

# MongoDB Connection String (when DB_TYPE=mongodb)
MONGODB_URL="mongodb://localhost:27017/task_management"

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# CORS Configuration
FRONTEND_URL=http://localhost:5173
